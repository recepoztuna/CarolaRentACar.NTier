@model Carola.EntityLayer.Entities.Customer

@{
    ViewData["Title"] = "Yeni Müşteri Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root {
        --bg-dark: #0d0f14;
        --bg-dark2: #13161e;
        --bg-dark3: #1a1e2a;
        --accent: #e8ff47;
        --accent-dim: rgba(232,255,71,.12);
        --accent2: #4f8dff;
        --accent2-dim: rgba(79,141,255,.12);
        --accent3: #ff9f47;
        --accent3-dim: rgba(255,159,71,.12);
        --danger: #ff5259;
        --success: #30e0a1;
        --border: rgba(255,255,255,.07);
        --text: #e2e8f0;
        --text-muted: #7a8499;
        --radius: 12px;
        --radius-lg: 18px;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .cc-root {
        padding: 28px;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
        color: var(--text);
        max-width: 860px;
    }

    /* ── Breadcrumb ── */
    .cc-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 6px;
    }

        .cc-breadcrumb a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color .2s;
        }

            .cc-breadcrumb a:hover {
                color: var(--accent);
            }

        .cc-breadcrumb span {
            color: var(--text);
        }

    /* ── Page Header ── */
    .cc-page-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 28px;
    }

    .cc-header-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        background: var(--accent-dim);
        border: 1px solid rgba(232,255,71,.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .cc-page-title {
        font-family: 'Syne', Georgia, sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
    }

    .cc-page-subtitle {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    /* ── Layout ── */
    .cc-layout {
        display: grid;
        grid-template-columns: 1fr 260px;
        gap: 18px;
        align-items: start;
    }

    @@media (max-width: 720px) {
        .cc-layout {
            grid-template-columns: 1fr;
        }
    }

    /* ── Card ── */
    .cc-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        animation: ccFadeUp .35s ease both;
    }

    @@keyframes ccFadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Section Header */
    .cc-section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 16px 22px;
        border-bottom: 1px solid var(--border);
        background: var(--bg-dark3);
    }

    .cc-section-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        flex-shrink: 0;
    }

        .cc-section-icon.yellow {
            background: var(--accent-dim);
        }

        .cc-section-icon.blue {
            background: var(--accent2-dim);
        }

        .cc-section-icon.orange {
            background: var(--accent3-dim);
        }

        .cc-section-icon.green {
            background: rgba(48,224,161,.1);
        }

    .cc-section-title {
        font-family: 'Syne', sans-serif;
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
    }

    .cc-section-desc {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 1px;
    }

    /* Form Body */
    .cc-form-body {
        padding: 22px;
    }

    .cc-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .cc-grid-1 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;
    }

    @@media (max-width: 540px) {
        .cc-grid-2 {
            grid-template-columns: 1fr;
        }
    }

    /* Field */
    .cc-field {
        display: flex;
        flex-direction: column;
        gap: 7px;
    }

        .cc-field.full {
            grid-column: 1 / -1;
        }

    .cc-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 5px;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .cc-required {
        color: var(--danger);
        font-size: 13px;
        line-height: 1;
    }

    .cc-input-wrap {
        position: relative;
    }

        .cc-input-wrap .cc-input {
            padding-left: 40px;
        }

    .cc-input-prefix {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 14px;
        color: var(--text-muted);
        pointer-events: none;
    }

    .cc-input {
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        color: var(--text);
        font-size: 13px;
        font-family: inherit;
        padding: 10px 14px;
        outline: none;
        width: 100%;
        transition: border-color .2s, box-shadow .2s, background .2s;
    }

        .cc-input:hover {
            border-color: rgba(255,255,255,.15);
            background: rgba(255,255,255,.02);
        }

        .cc-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-dim);
            background: rgba(232,255,71,.03);
        }

        .cc-input::placeholder {
            color: var(--text-muted);
        }

        .cc-input.error {
            border-color: rgba(255,82,89,.5) !important;
            box-shadow: 0 0 0 3px rgba(255,82,89,.1) !important;
        }

    .cc-hint {
        font-size: 11px;
        color: var(--text-muted);
    }

    .cc-val-msg {
        font-size: 11px;
        color: var(--danger);
        display: flex;
        align-items: center;
        gap: 3px;
    }

    .cc-divider {
        border: none;
        border-top: 1px solid var(--border);
    }

    /* ── Sidebar ── */
    .cc-sidebar {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    /* Preview card */
    .cc-preview-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        animation: ccFadeUp .4s ease .05s both;
    }

    .cc-preview-body {
        padding: 20px;
    }

    .cc-preview-avatar-wrap {
        display: flex;
        justify-content: center;
        margin-bottom: 16px;
    }

    .cc-preview-avatar {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        background: var(--accent-dim);
        border: 1px solid rgba(232,255,71,.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        font-weight: 700;
        color: var(--accent);
        font-family: 'Syne', sans-serif;
        transition: all .3s;
    }

    .cc-preview-name {
        text-align: center;
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 3px;
        transition: all .2s;
    }

    .cc-preview-sub {
        text-align: center;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 16px;
    }

    .cc-preview-divider {
        border: none;
        border-top: 1px solid var(--border);
        margin-bottom: 14px;
    }

    .cc-preview-row {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 10px;
    }

        .cc-preview-row:last-child {
            margin-bottom: 0;
        }

    .cc-preview-icon {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        flex-shrink: 0;
    }

        .cc-preview-icon.blue {
            background: var(--accent2-dim);
        }

        .cc-preview-icon.orange {
            background: var(--accent3-dim);
        }

        .cc-preview-icon.green {
            background: rgba(48,224,161,.08);
        }

        .cc-preview-icon.yellow {
            background: var(--accent-dim);
        }

    .cc-preview-row-label {
        font-size: 10px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .cc-preview-row-val {
        font-size: 12px;
        color: var(--text);
        line-height: 1.3;
        word-break: break-all;
    }

    .cc-preview-empty {
        font-size: 11px;
        color: rgba(255,255,255,.2);
        font-style: italic;
    }

    /* Tips card */
    .cc-tips-card {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 16px 18px;
        animation: ccFadeUp .4s ease .1s both;
    }

    .cc-tips-title {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .cc-tip {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 9px;
        font-size: 12px;
        color: var(--text-muted);
        line-height: 1.5;
    }

        .cc-tip:last-child {
            margin-bottom: 0;
        }

    .cc-tip-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--accent);
        flex-shrink: 0;
        margin-top: 6px;
    }

    /* Validation summary */
    .cc-val-summary {
        background: rgba(255,82,89,.08);
        border: 1px solid rgba(255,82,89,.2);
        border-radius: var(--radius);
        padding: 12px 16px;
        margin-bottom: 18px;
        display: none;
    }

        .cc-val-summary.show {
            display: block;
        }

    .cc-val-summary-title {
        font-size: 13px;
        font-weight: 600;
        color: var(--danger);
        margin-bottom: 6px;
    }

    .cc-val-summary ul {
        padding-left: 16px;
    }

    .cc-val-summary li {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 3px;
    }

    /* Actions */
    .cc-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        padding: 18px 22px;
        border-top: 1px solid var(--border);
        background: var(--bg-dark3);
    }

    .btn-accent {
        background: var(--accent);
        color: #0d0f14;
        border: none;
        border-radius: 10px;
        padding: 10px 22px;
        font-size: 13px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: opacity .2s;
    }

        .btn-accent:hover {
            opacity: .85;
            color: #0d0f14;
        }

    .btn-ghost {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: all .2s;
    }

        .btn-ghost:hover {
            background: var(--bg-dark3);
            color: var(--text);
            border-color: rgba(255,255,255,.15);
        }
</style>

<div class="cc-root">

    <div class="cc-breadcrumb">
        <a asp-controller="Customer" asp-action="CustomerList">Müşteri Yönetimi</a>
        <span>›</span>
        <span>Yeni Müşteri Ekle</span>
    </div>

    <div class="cc-page-header">
        <div class="cc-header-icon">👤</div>
        <div>
            <h1 class="cc-page-title">Yeni Müşteri Ekle</h1>
            <p class="cc-page-subtitle">Sisteme yeni bir müşteri kaydı oluşturun.</p>
        </div>
    </div>

    <!-- Validation Summary -->
    <div class="cc-val-summary" id="ccValSummary">
        <div class="cc-val-summary-title">⚠️ Lütfen aşağıdaki hataları düzeltin</div>
        <ul id="ccValList"></ul>
    </div>

    <form method="post" id="ccForm" novalidate>
        @Html.AntiForgeryToken()

        <div class="cc-layout">

            <!-- ── Left: Form ── -->
            <div>

                <!-- Kişisel Bilgiler -->
                <div class="cc-card" style="margin-bottom:16px;">
                    <div class="cc-section-header">
                        <div class="cc-section-icon yellow">👤</div>
                        <div>
                            <div class="cc-section-title">Kişisel Bilgiler</div>
                            <div class="cc-section-desc">Ad, soyad ve doğum tarihi</div>
                        </div>
                    </div>
                    <div class="cc-form-body">
                        <div class="cc-grid-2">

                            <!-- Ad -->
                            <div class="cc-field">
                                <label class="cc-label" for="FirstName">
                                    Ad <span class="cc-required">*</span>
                                </label>
                                <div class="cc-input-wrap">
                                    <span class="cc-input-prefix">✏️</span>
                                    <input asp-for="FirstName" class="cc-input" id="FirstName"
                                           placeholder="Örn: Ahmet"
                                           autocomplete="given-name"
                                           oninput="ccPreview()" />
                                </div>
                                <span asp-validation-for="FirstName" class="cc-val-msg"></span>
                            </div>

                            <!-- Soyad -->
                            <div class="cc-field">
                                <label class="cc-label" for="LastName">
                                    Soyad <span class="cc-required">*</span>
                                </label>
                                <div class="cc-input-wrap">
                                    <span class="cc-input-prefix">✏️</span>
                                    <input asp-for="LastName" class="cc-input" id="LastName"
                                           placeholder="Örn: Yılmaz"
                                           autocomplete="family-name"
                                           oninput="ccPreview()" />
                                </div>
                                <span asp-validation-for="LastName" class="cc-val-msg"></span>
                            </div>

                            <!-- Doğum Tarihi -->
                            <div class="cc-field full">
                                <label class="cc-label" for="BirthDate">
                                    Doğum Tarihi <span class="cc-required">*</span>
                                </label>
                                <div class="cc-input-wrap">
                                    <span class="cc-input-prefix">🎂</span>
                                    <input asp-for="BirthDate" type="date" class="cc-input" id="BirthDate"
                                           oninput="ccPreview()" />
                                </div>
                                <span asp-validation-for="BirthDate" class="cc-val-msg"></span>
                                <span class="cc-hint">Müşterinin sürücü belgesi ile uyumlu doğum tarihini girin.</span>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- İletişim Bilgileri -->
                <div class="cc-card" style="margin-bottom:16px;">
                    <div class="cc-section-header">
                        <div class="cc-section-icon blue">📬</div>
                        <div>
                            <div class="cc-section-title">İletişim Bilgileri</div>
                            <div class="cc-section-desc">E-posta ve telefon numarası</div>
                        </div>
                    </div>
                    <div class="cc-form-body">
                        <div class="cc-grid-2">

                            <!-- E-posta -->
                            <div class="cc-field">
                                <label class="cc-label" for="Email">
                                    E-posta <span class="cc-required">*</span>
                                </label>
                                <div class="cc-input-wrap">
                                    <span class="cc-input-prefix">📧</span>
                                    <input asp-for="Email" type="email" class="cc-input" id="Email"
                                           placeholder="ornek@email.com"
                                           autocomplete="email"
                                           oninput="ccPreview()" />
                                </div>
                                <span asp-validation-for="Email" class="cc-val-msg"></span>
                            </div>

                            <!-- Telefon -->
                            <div class="cc-field">
                                <label class="cc-label" for="Phone">
                                    Telefon <span class="cc-required">*</span>
                                </label>
                                <div class="cc-input-wrap">
                                    <span class="cc-input-prefix">📞</span>
                                    <input asp-for="Phone" type="tel" class="cc-input" id="Phone"
                                           placeholder="05XX XXX XX XX"
                                           autocomplete="tel"
                                           oninput="ccPreview()" />
                                </div>
                                <span asp-validation-for="Phone" class="cc-val-msg"></span>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- Ehliyet Bilgisi -->
                <div class="cc-card">
                    <div class="cc-section-header">
                        <div class="cc-section-icon orange">🪪</div>
                        <div>
                            <div class="cc-section-title">Sürücü Belgesi</div>
                            <div class="cc-section-desc">Ehliyet numarası doğrulaması</div>
                        </div>
                    </div>
                    <div class="cc-form-body">
                        <div class="cc-grid-1">

                            <!-- Ehliyet No -->
                            <div class="cc-field">
                                <label class="cc-label" for="DriverLicenseNumber">
                                    Ehliyet Numarası <span class="cc-required">*</span>
                                </label>
                                <div class="cc-input-wrap">
                                    <span class="cc-input-prefix">🪪</span>
                                    <input asp-for="DriverLicenseNumber" class="cc-input" id="DriverLicenseNumber"
                                           placeholder="Örn: B123456789"
                                           style="font-family:monospace;letter-spacing:.06em;text-transform:uppercase;"
                                           oninput="this.value=this.value.toUpperCase();ccPreview()" />
                                </div>
                                <span asp-validation-for="DriverLicenseNumber" class="cc-val-msg"></span>
                                <span class="cc-hint">Geçerli bir Türkiye sürücü belgesi numarası girin. Kiralama esnasında doğrulanacaktır.</span>
                            </div>

                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="cc-actions">
                        <a asp-controller="Customer" asp-action="CustomerList" class="btn-ghost">✕ İptal</a>
                        <button type="submit" class="btn-accent" id="ccSubmitBtn">＋ Müşteriyi Kaydet</button>
                    </div>
                </div>

            </div>

            <!-- ── Right: Sidebar ── -->
            <div class="cc-sidebar">

                <!-- Live Preview -->
                <div class="cc-preview-card">
                    <div class="cc-section-header">
                        <div class="cc-section-icon green">👁️</div>
                        <div>
                            <div class="cc-section-title">Canlı Önizleme</div>
                            <div class="cc-section-desc">Tabloda böyle görünecek</div>
                        </div>
                    </div>
                    <div class="cc-preview-body">
                        <div class="cc-preview-avatar-wrap">
                            <div class="cc-preview-avatar" id="ccPrevAvatar">?</div>
                        </div>
                        <div class="cc-preview-name" id="ccPrevName">Ad Soyad</div>
                        <div class="cc-preview-sub" id="ccPrevAge">— yaş</div>

                        <hr class="cc-preview-divider" />

                        <div class="cc-preview-row">
                            <div class="cc-preview-icon blue">📧</div>
                            <div>
                                <div class="cc-preview-row-label">E-posta</div>
                                <div class="cc-preview-row-val cc-preview-empty" id="ccPrevEmail">girilmedi</div>
                            </div>
                        </div>
                        <div class="cc-preview-row">
                            <div class="cc-preview-icon orange">📞</div>
                            <div>
                                <div class="cc-preview-row-label">Telefon</div>
                                <div class="cc-preview-row-val cc-preview-empty" id="ccPrevPhone">girilmedi</div>
                            </div>
                        </div>
                        <div class="cc-preview-row">
                            <div class="cc-preview-icon yellow">🪪</div>
                            <div>
                                <div class="cc-preview-row-label">Ehliyet No</div>
                                <div class="cc-preview-row-val cc-preview-empty" id="ccPrevLicense"
                                     style="font-family:monospace;letter-spacing:.05em;">
                                    girilmedi
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tips -->
                <div class="cc-tips-card">
                    <div class="cc-tips-title">💡 Bilgi</div>
                    <div class="cc-tip"><div class="cc-tip-dot"></div><span>Müşteri kaydı oluşturulduktan sonra kiralama işlemi başlatılabilir.</span></div>
                    <div class="cc-tip"><div class="cc-tip-dot"></div><span>Ehliyet numarası araç teslimi sırasında fiziksel olarak doğrulanmalıdır.</span></div>
                    <div class="cc-tip"><div class="cc-tip-dot"></div><span>E-posta adresi bildirimler ve rezervasyon onayları için kullanılacaktır.</span></div>
                    <div class="cc-tip"><div class="cc-tip-dot"></div><span>Müşteri 18 yaşından küçükse kayıt tamamlanamaz.</span></div>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        /* ── Live Preview ── */
        function ccPreview() {
            var fn      = document.getElementById('FirstName').value.trim();
            var ln      = document.getElementById('LastName').value.trim();
            var email   = document.getElementById('Email').value.trim();
            var phone   = document.getElementById('Phone').value.trim();
            var license = document.getElementById('DriverLicenseNumber').value.trim();
            var birth   = document.getElementById('BirthDate').value;

            /* Avatar */
            var initials = ((fn ? fn.charAt(0) : '') + (ln ? ln.charAt(0) : '')).toUpperCase() || '?';
            document.getElementById('ccPrevAvatar').textContent = initials;

            /* Name */
            document.getElementById('ccPrevName').textContent =
                (fn || ln) ? (fn + ' ' + ln).trim() : 'Ad Soyad';

            /* Age */
            if (birth) {
                var b   = new Date(birth);
                var now = new Date();
                var age = now.getFullYear() - b.getFullYear();
                var m   = now.getMonth() - b.getMonth();
                if (m < 0 || (m === 0 && now.getDate() < b.getDate())) age--;
                document.getElementById('ccPrevAge').textContent = age >= 0 ? age + ' yaş' : '— yaş';
            } else {
                document.getElementById('ccPrevAge').textContent = '— yaş';
            }

            /* Fields */
            ccSetPrev('ccPrevEmail',   email,   'girilmedi');
            ccSetPrev('ccPrevPhone',   phone,   'girilmedi');
            ccSetPrev('ccPrevLicense', license, 'girilmedi');
        }

        function ccSetPrev(id, val, empty) {
            var el = document.getElementById(id);
            if (val) {
                el.textContent = val;
                el.classList.remove('cc-preview-empty');
            } else {
                el.textContent = empty;
                el.classList.add('cc-preview-empty');
            }
        }

        /* ── Client-side Validation ── */
        document.getElementById('ccForm').addEventListener('submit', function (e) {
            var rules = [
                { id: 'FirstName',           label: 'Ad',               type: 'required' },
                { id: 'LastName',            label: 'Soyad',            type: 'required' },
                { id: 'Email',               label: 'E-posta',          type: 'email'    },
                { id: 'Phone',               label: 'Telefon',          type: 'required' },
                { id: 'DriverLicenseNumber', label: 'Ehliyet Numarası', type: 'required' },
                { id: 'BirthDate',           label: 'Doğum Tarihi',     type: 'date'     },
            ];

            var errors = [];

            rules.forEach(function (r) {
                var el  = document.getElementById(r.id);
                var val = el.value.trim();
                var ok  = true;

                if (r.type === 'required' && !val) {
                    errors.push(r.label + ' alanı zorunludur.');
                    ok = false;
                }
                if (r.type === 'email') {
                    if (!val) { errors.push('E-posta alanı zorunludur.'); ok = false; }
                    else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(val)) { errors.push('Geçerli bir e-posta adresi girin.'); ok = false; }
                }
                if (r.type === 'date') {
                    if (!val) {
                        errors.push('Doğum tarihi zorunludur.');
                        ok = false;
                    } else {
                        var age = new Date().getFullYear() - new Date(val).getFullYear();
                        if (age < 18) { errors.push('Müşteri en az 18 yaşında olmalıdır.'); ok = false; }
                        if (age > 100) { errors.push('Geçerli bir doğum tarihi girin.'); ok = false; }
                    }
                }

                if (!ok) {
                    el.classList.add('error');
                    el.addEventListener('input', function () { el.classList.remove('error'); }, { once: true });
                }
            });

            var summary = document.getElementById('ccValSummary');
            var list    = document.getElementById('ccValList');

            if (errors.length) {
                e.preventDefault();
                list.innerHTML = errors.map(function (err) { return '<li>' + err + '</li>'; }).join('');
                summary.classList.add('show');
                summary.scrollIntoView({ behavior: 'smooth', block: 'start' });
            } else {
                summary.classList.remove('show');
                var btn = document.getElementById('ccSubmitBtn');
                btn.disabled = true;
                btn.innerHTML = '⏳ Kaydediliyor...';
            }
        });
    </script>
}


