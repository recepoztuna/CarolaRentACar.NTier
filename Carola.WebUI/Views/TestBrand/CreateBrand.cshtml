
@{
    Layout = null;
}

@model Carola.EntityLayer.Entities.Brand

<form method="post">
    @Html.AntiForgeryToken()

    <div>
        <label asp-for="BrandName">Marka Adı</label>
        <input asp-for="BrandName" type="text" />
        <span asp-validation-for="BrandName"></span>
    </div>

    <div>
        <label asp-for="LogoUrl">Logo URL</label>
        <input asp-for="LogoUrl" type="text" />
        <span asp-validation-for="LogoUrl"></span>
    </div>

    <div>
        <label asp-for="Status">Durum</label>
        <input asp-for="Status" type="checkbox" />
        <span asp-validation-for="Status"></span>
    </div>

    <button type="submit">Kaydet</button>
</form>



