@model List<Carola.DtoLayer.Dtos.BrandDtos.ResultBrandDto>

<section class="brand-section pt_120 pb_120">
    <div class="container">
        <div class="section-title-box">
            <div class="section-title">
                <span class="sub-title">Markalar</span>
                <h2 class="title">Premium Araç Markalarını Keşfet</h2>
            </div>
            <div class="show-all-btn">
                <a href="" class="btn-style-three">Tüm Markaları Gör</a>
            </div>
        </div>
        <div class="brand-outer-box">
            @foreach (var item in Model)
            {
                <div class="single-brand-item">
                    <div class="brand-image" style="width:100%; height:80px; display:flex; align-items:center; justify-content:center;">
                        <img src="@item.LogoUrl"
                             alt="@item.BrandName"
                             style="width:auto; height:60px; object-fit:contain;"
                             onerror="this.src='/carola/carola/assets/images/brands/audi.png'">
                    </div>
                    <div class="brand-title">
                        <h6>@item.BrandName</h6>
                    </div>
                </div>
            }
        </div>
    </div>
</section>