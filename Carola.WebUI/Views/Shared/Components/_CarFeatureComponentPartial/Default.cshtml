@model List<Carola.DtoLayer.Dtos.FeatureDtos.ResultFeatureDto>

<section class="why-chooseus-section pt_120 pb_90">
    <div class="shape-three"><img src="~/carola/carola/assets/images/shape/shape-3.png" alt=""></div>
    <div class="shape-four"><img src="~/carola/carola/assets/images/shape/shape-4.png" alt=""></div>
    <div class="container">
        <div class="section-title centred mb_60">
            <span class="sub-title">Neden Biz?</span>
            <h2 class="title">Kendi Tarzınızla Dünyayı Keşfedin</h2>
        </div>
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-xl-3 col-lg-3 col-md-6 col-sm-12 d-flex">
                    <div class="why-chooseus-block w-100">
                        <div class="why-chooseus-icon light">
                            <i class="@item.IconUrl"></i>
                        </div>
                        <h5 class="why-chooseus-title">@item.Title</h5>
                        <p class="why-chooseus-text">@item.Description</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>