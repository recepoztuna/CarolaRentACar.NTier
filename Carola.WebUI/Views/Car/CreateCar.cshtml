@model Carola.EntityLayer.Entities.Car
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "CreateCar";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    :root {
        --bg-dark: #0d0f14;
        --bg-dark2: #13161e;
        --bg-dark3: #1a1e2a;
        --accent: #e8ff47;
        --accent-dim: rgba(232,255,71,.12);
        --accent2: #4f8dff;
        --accent2-dim: rgba(79,141,255,.12);
        --accent3: #ff9f47;
        --accent3-dim: rgba(255,159,71,.12);
        --danger: #ff5259;
        --danger-dim: rgba(255,82,89,.1);
        --success: #30e0a1;
        --border: rgba(255,255,255,.07);
        --border-focus: rgba(232,255,71,.45);
        --text: #e2e8f0;
        --text-muted: #7a8499;
        --radius: 12px;
        --radius-lg: 18px;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .cc-root {
        padding: 28px;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
        color: var(--text);
        max-width: 960px;
    }

    /* ── Breadcrumb ── */
    .cc-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 6px;
    }

        .cc-breadcrumb a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color .2s;
        }

            .cc-breadcrumb a:hover {
                color: var(--accent);
            }

        .cc-breadcrumb span {
            color: var(--text);
        }

    /* ── Page Header ── */
    .cc-page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }

    .cc-page-title {
        font-family: 'Syne', Georgia, sans-serif;
        font-size: 26px;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
    }

    .cc-page-subtitle {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 5px;
    }

    /* ── Back Button ── */
    .btn-back {
        background: var(--bg-dark2);
        color: var(--text-muted);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 500;
        font-family: inherit;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: all .2s;
    }

        .btn-back:hover {
            border-color: rgba(255,255,255,.15);
            color: var(--text);
        }

    /* ── Form Layout ── */
    .cc-form-body {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        animation: ccFadeUp .4s ease both;
    }

    @@media (max-width: 640px) {
        .cc-form-body {
            grid-template-columns: 1fr;
        }
    }

    @@keyframes ccFadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Sections */
    .cc-section {
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 22px 22px 20px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

        .cc-section.full {
            grid-column: 1 / -1;
        }

        .cc-section.image-preview-section {
            grid-column: 1 / -1;
        }

    .cc-section-title {
        font-family: 'Syne', sans-serif;
        font-size: 13px;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: .08em;
        display: flex;
        align-items: center;
        gap: 8px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
    }

    .cc-section-title-icon {
        width: 26px;
        height: 26px;
        border-radius: 7px;
        display: grid;
        place-items: center;
        font-size: 14px;
        flex-shrink: 0;
    }

        .cc-section-title-icon.yellow {
            background: var(--accent-dim);
        }

        .cc-section-title-icon.blue {
            background: var(--accent2-dim);
        }

        .cc-section-title-icon.orange {
            background: var(--accent3-dim);
        }

        .cc-section-title-icon.green {
            background: rgba(48,224,161,.1);
        }

    /* ── Field Group ── */
    .cc-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .cc-field-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    @@media (max-width: 420px) {
        .cc-field-row {
            grid-template-columns: 1fr;
        }
    }

    .cc-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        letter-spacing: .03em;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .cc-label .req {
            color: var(--danger);
        }

    /* ── Inputs ── */
    .cc-input,
    .cc-select,
    .cc-textarea {
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        padding: 10px 14px;
        font-size: 13px;
        font-family: inherit;
        outline: none;
        transition: border .2s, box-shadow .2s;
        width: 100%;
    }

        .cc-input:focus,
        .cc-select:focus,
        .cc-textarea:focus {
            border-color: var(--border-focus);
            box-shadow: 0 0 0 3px var(--accent-dim);
        }

        .cc-input::placeholder,
        .cc-textarea::placeholder {
            color: var(--text-muted);
            opacity: 1;
        }

    .cc-select {
        cursor: pointer;
        appearance: none;
        -webkit-appearance: none;
    }

    .cc-select-wrap {
        position: relative;
    }

        .cc-select-wrap::after {
            content: '▾';
            position: absolute;
            right: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 12px;
            pointer-events: none;
        }

    .cc-textarea {
        resize: vertical;
        min-height: 80px;
    }

    /* Number input — hide spinners */
    .cc-input[type="number"]::-webkit-inner-spin-button,
    .cc-input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
    }

    .cc-input[type="number"] {
        -moz-appearance: textfield;
    }

    /* Input with prefix */
    .cc-input-wrap {
        position: relative;
        display: flex;
        align-items: center;
    }

    .cc-input-prefix {
        position: absolute;
        left: 0;
        height: 100%;
        padding: 0 12px;
        display: flex;
        align-items: center;
        font-size: 12px;
        font-weight: 600;
        color: var(--accent);
        background: var(--accent-dim);
        border-right: 1px solid var(--border);
        border-radius: 10px 0 0 10px;
        pointer-events: none;
        user-select: none;
        white-space: nowrap;
    }

    .cc-input-wrap .cc-input {
        padding-left: 56px;
    }

    .cc-input-wrap.wide-prefix .cc-input {
        padding-left: 72px;
    }

    .cc-input-suffix {
        position: absolute;
        right: 0;
        height: 100%;
        padding: 0 12px;
        display: flex;
        align-items: center;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        pointer-events: none;
        user-select: none;
    }

    /* Toggle / Availability switch */
    .cc-toggle-wrap {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 12px 14px;
        cursor: pointer;
        transition: border .2s;
    }

        .cc-toggle-wrap:hover {
            border-color: rgba(255,255,255,.14);
        }

    .cc-toggle-left {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .cc-toggle-name {
        font-size: 13px;
        font-weight: 500;
        color: var(--text);
    }

    .cc-toggle-hint {
        font-size: 11px;
        color: var(--text-muted);
    }

    .cc-switch {
        position: relative;
        width: 44px;
        height: 24px;
        flex-shrink: 0;
    }

        .cc-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .cc-switch-track {
        position: absolute;
        cursor: pointer;
        inset: 0;
        background: var(--bg-dark);
        border: 1px solid var(--border);
        border-radius: 12px;
        transition: background .25s, border .25s;
    }

        .cc-switch-track::before {
            content: '';
            position: absolute;
            height: 16px;
            width: 16px;
            left: 3px;
            top: 3px;
            background: var(--text-muted);
            border-radius: 50%;
            transition: transform .25s, background .25s;
        }

    .cc-switch input:checked + .cc-switch-track {
        background: var(--accent-dim);
        border-color: rgba(232,255,71,.4);
    }

        .cc-switch input:checked + .cc-switch-track::before {
            transform: translateX(20px);
            background: var(--accent);
        }

    /* Image preview */
    .cc-img-preview-box {
        background: var(--bg-dark3);
        border: 2px dashed var(--border);
        border-radius: var(--radius);
        height: 180px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 13px;
        position: relative;
        overflow: hidden;
        transition: border .2s;
    }

        .cc-img-preview-box:hover {
            border-color: rgba(232,255,71,.25);
        }

        .cc-img-preview-box .icon {
            font-size: 36px;
            opacity: .45;
        }

    #ccImgPreview {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
        border-radius: calc(var(--radius) - 2px);
    }

    #ccImgPreviewOverlay {
        position: absolute;
        inset: 0;
        border-radius: calc(var(--radius) - 2px);
        background: rgba(0,0,0,.45);
        display: none;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        color: #fff;
        gap: 6px;
    }

    .cc-img-preview-box:hover #ccImgPreviewOverlay {
        display: flex;
    }

    /* Validation */
    .field-validation-error {
        font-size: 11px;
        color: var(--danger);
        display: flex;
        align-items: center;
        gap: 4px;
    }

        .field-validation-error::before {
            content: '⚠';
            font-size: 10px;
        }

    .input-validation-error {
        border-color: rgba(255,82,89,.5) !important;
        box-shadow: 0 0 0 3px rgba(255,82,89,.1) !important;
    }

    /* ── Submit Bar ── */
    .cc-submit-bar {
        grid-column: 1 / -1;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 12px;
        padding: 18px 22px;
        background: var(--bg-dark2);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
    }

    .btn-submit {
        background: var(--accent);
        color: #0d0f14;
        border: none;
        border-radius: 10px;
        padding: 11px 28px;
        font-size: 14px;
        font-weight: 700;
        font-family: 'Syne', sans-serif;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: opacity .2s, transform .15s;
        letter-spacing: .02em;
    }

        .btn-submit:hover {
            opacity: .88;
            transform: translateY(-1px);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

    .btn-reset {
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 13px;
        font-weight: 500;
        font-family: inherit;
        cursor: pointer;
        transition: all .2s;
    }

        .btn-reset:hover {
            border-color: rgba(255,255,255,.15);
            color: var(--text);
        }

    /* Step indicator */
    .cc-steps {
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 24px;
        overflow-x: auto;
        padding-bottom: 2px;
    }

    .cc-step {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 14px;
        font-size: 12px;
        font-weight: 500;
        color: var(--text-muted);
        white-space: nowrap;
    }

    .cc-step-num {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-size: 11px;
        font-weight: 700;
        background: var(--bg-dark3);
        border: 1px solid var(--border);
        color: var(--text-muted);
        flex-shrink: 0;
    }

    .cc-step.done .cc-step-num {
        background: var(--accent-dim);
        border-color: rgba(232,255,71,.3);
        color: var(--accent);
    }

    .cc-step-sep {
        width: 24px;
        height: 1px;
        background: var(--border);
        flex-shrink: 0;
    }
</style>

<div class="cl-root" style="padding:28px;font-family:'DM Sans','Segoe UI',sans-serif;color:#e2e8f0;max-width:960px;">

    <div class="cc-breadcrumb">
        <a asp-controller="Car" asp-action="Index">Araç Yönetimi</a>
        <span>›</span>
        <a asp-controller="Car" asp-action="CarList">Araç Listesi</a>
        <span>›</span>
        <span>Yeni Araç Ekle</span>
    </div>

    <div class="cc-page-header">
        <div>
            <h1 class="cc-page-title">Yeni Araç Ekle</h1>
            <p class="cc-page-subtitle">Filoya yeni bir araç kaydı oluşturun.</p>
        </div>
        <a asp-controller="Car" asp-action="CarList" class="btn-back">← Listeye Dön</a>
    </div>

    <form asp-controller="Car" asp-action="CreateCar" method="post">
        @Html.AntiForgeryToken()

        <div class="cc-form-body">

            <!-- ── Section 1: Temel Bilgiler ── -->
            <div class="cc-section">
                <div class="cc-section-title">
                    <div class="cc-section-title-icon yellow">🚗</div>
                    Temel Bilgiler
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="Brand">Marka <span class="req">*</span></label>
                    <input class="cc-input" asp-for="Brand" placeholder="örn. Toyota" autocomplete="off" />
                    <span class="field-validation-error" asp-validation-for="Brand"></span>
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="Model">Model <span class="req">*</span></label>
                    <input class="cc-input" asp-for="Model" placeholder="örn. Corolla" autocomplete="off" />
                    <span class="field-validation-error" asp-validation-for="Model"></span>
                </div>

                <div class="cc-field-row">
                    <div class="cc-field">
                        <label class="cc-label" asp-for="ModelYear">Model Yılı <span class="req">*</span></label>
                        <input class="cc-input" asp-for="ModelYear" type="number"
                               placeholder="2024" min="1990" max="2030" />
                        <span class="field-validation-error" asp-validation-for="ModelYear"></span>
                    </div>
                    <div class="cc-field">
                        <label class="cc-label" asp-for="PlateNumber">Plaka <span class="req">*</span></label>
                        <input class="cc-input" asp-for="PlateNumber"
                               placeholder="34 ABC 123"
                               style="text-transform:uppercase;letter-spacing:.06em;font-weight:600;"
                               autocomplete="off" />
                        <span class="field-validation-error" asp-validation-for="PlateNumber"></span>
                    </div>
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="CategoryId">Kategori <span class="req">*</span></label>
                    <div class="cc-select-wrap">
                        <select class="cc-select" asp-for="CategoryId"
                                asp-items="ViewBag.Categories">
                            <option value="">— Kategori Seçin —</option>
                        </select>
                    </div>
                    <span class="field-validation-error" asp-validation-for="CategoryId"></span>
                </div>
            </div>

            <!-- ── Section 2: Fiyat & Durum ── -->
            <div class="cc-section">
                <div class="cc-section-title">
                    <div class="cc-section-title-icon orange">💰</div>
                    Fiyat & Durum
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="DailyPrice">Günlük Fiyat <span class="req">*</span></label>
                    <div class="cc-input-wrap">
                        <span class="cc-input-prefix">₺</span>
                        <input class="cc-input" asp-for="DailyPrice"
                               type="number" step="0.01" min="0"
                               placeholder="0.00" />
                    </div>
                    <span class="field-validation-error" asp-validation-for="DailyPrice"></span>
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="Mileage">Kilometre <span class="req">*</span></label>
                    <div class="cc-input-wrap">
                        <span class="cc-input-prefix" style="font-size:11px;">km</span>
                        <input class="cc-input" asp-for="Mileage"
                               type="number" min="0"
                               placeholder="0" />
                    </div>
                    <span class="field-validation-error" asp-validation-for="Mileage"></span>
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="IsAvailable">Araç Durumu</label>
                    <label class="cc-toggle-wrap" for="IsAvailable">
                        <div class="cc-toggle-left">
                            <span class="cc-toggle-name">Müsaitlik</span>
                            <span class="cc-toggle-hint">Aracın kiralanmaya uygun olup olmadığını belirtir.</span>
                        </div>
                        <label class="cc-switch">
                            <input type="checkbox" asp-for="IsAvailable" id="IsAvailable" />
                            <span class="cc-switch-track"></span>
                        </label>
                    </label>
                </div>
            </div>

            <!-- ── Section 3: Teknik Özellikler ── -->
            <div class="cc-section">
                <div class="cc-section-title">
                    <div class="cc-section-title-icon blue">⚙️</div>
                    Teknik Özellikler
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="FuelType">Yakıt Tipi <span class="req">*</span></label>
                    <div class="cc-select-wrap">
                        <select class="cc-select" asp-for="FuelType">
                            <option value="">— Yakıt Tipi Seçin —</option>
                            <option value="Benzin">Benzin</option>
                            <option value="Dizel">Dizel</option>
                            <option value="Elektrik">Elektrik</option>
                            <option value="Hibrit">Hibrit</option>
                            <option value="LPG">LPG</option>
                        </select>
                    </div>
                    <span class="field-validation-error" asp-validation-for="FuelType"></span>
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="TransmissionType">Vites Tipi <span class="req">*</span></label>
                    <div class="cc-select-wrap">
                        <select class="cc-select" asp-for="TransmissionType">
                            <option value="">— Vites Tipi Seçin —</option>
                            <option value="Manuel">Manuel</option>
                            <option value="Otomatik">Otomatik</option>
                            <option value="Yarı Otomatik">Yarı Otomatik</option>
                        </select>
                    </div>
                    <span class="field-validation-error" asp-validation-for="TransmissionType"></span>
                </div>
            </div>

            <!-- ── Section 4: Kapasite ── -->
            <div class="cc-section">
                <div class="cc-section-title">
                    <div class="cc-section-title-icon green">🧳</div>
                    Kapasite
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="SeatCount">Koltuk Sayısı <span class="req">*</span></label>
                    <div class="cc-input-wrap">
                        <input class="cc-input" asp-for="SeatCount"
                               type="number" min="1" max="20"
                               placeholder="5" />
                        <span class="cc-input-suffix">kişi</span>
                    </div>
                    <span class="field-validation-error" asp-validation-for="SeatCount"></span>
                </div>

                <div class="cc-field">
                    <label class="cc-label" asp-for="LuggageCapacity">Bagaj Kapasitesi <span class="req">*</span></label>
                    <div class="cc-input-wrap">
                        <input class="cc-input" asp-for="LuggageCapacity"
                               type="number" min="0"
                               placeholder="3" />
                        <span class="cc-input-suffix">adet</span>
                    </div>
                    <span class="field-validation-error" asp-validation-for="LuggageCapacity"></span>
                </div>
            </div>

            <!-- ── Section 5: Araç Görseli (full width) ── -->
            <div class="cc-section image-preview-section">
                <div class="cc-section-title">
                    <div class="cc-section-title-icon yellow">🖼️</div>
                    Araç Görseli
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start;">
                    <div class="cc-field" style="grid-column:1">
                        <label class="cc-label" asp-for="ImageUrl">Görsel URL</label>
                        <input class="cc-input" asp-for="ImageUrl"
                               id="ccImageUrlInput"
                               placeholder="https://example.com/car.jpg"
                               oninput="ccPreviewImage(this.value)" />
                        <span class="field-validation-error" asp-validation-for="ImageUrl"></span>
                        <span style="font-size:11px;color:var(--text-muted);margin-top:2px;">
                            Geçerli bir görsel URL'si girin. Boş bırakırsanız varsayılan ikon gösterilir.
                        </span>
                    </div>

                    <div style="grid-column:2;">
                        <div style="font-size:12px;font-weight:600;color:var(--text-muted);letter-spacing:.03em;margin-bottom:8px;">ÖNİZLEME</div>
                        <div class="cc-img-preview-box" id="ccImgBox">
                            <div class="icon">🚗</div>
                            <span>Görsel URL girildiğinde burada gösterilir</span>
                            <img id="ccImgPreview" src="" alt="Araç Görseli"
                                 onerror="ccPreviewError()" />
                            <div id="ccImgPreviewOverlay">🔍 Önizle</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Submit Bar ── -->
            <div class="cc-submit-bar">
                <button type="button" class="btn-reset" onclick="if(confirm('Formu sıfırlamak istediğinizden emin misiniz?')) this.closest('form').reset(), ccPreviewImage('')">
                    ↺ Sıfırla
                </button>
                <button type="submit" class="btn-submit">
                    🚗 Aracı Kaydet
                </button>
            </div>

        </div><!-- /.cc-form-body -->

    </form>
</div>

<script>
    function ccPreviewImage(url) {
        var img     = document.getElementById('ccImgPreview');
        var overlay = document.getElementById('ccImgPreviewOverlay');
        var box     = document.getElementById('ccImgBox');

        if (!url || url.trim() === '') {
            img.style.display     = 'none';
            overlay.style.display = 'none';
            return;
        }

        img.src             = url.trim();
        img.style.display   = 'block';
        overlay.style.display = '';
    }

    function ccPreviewError() {
        var img     = document.getElementById('ccImgPreview');
        var overlay = document.getElementById('ccImgPreviewOverlay');
        img.style.display     = 'none';
        overlay.style.display = 'none';
    }

    /* Plaka otomatik büyük harf */
    document.querySelector('input[name="PlateNumber"]').addEventListener('input', function() {
        var pos = this.selectionStart;
        this.value = this.value.toUpperCase();
        this.setSelectionRange(pos, pos);
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}


