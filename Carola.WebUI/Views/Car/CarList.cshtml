@model List<Carola.EntityLayer.Entities.Car>

@{
    ViewData["Title"] = "CarList";
    Layout = "~/Views/AdminLayout/Index.cshtml";

    var totalCount     = Model.Count();
    var availableCount = Model.Count(c => c.IsAvailable);
    var rentedCount    = Model.Count(c => !c.IsAvailable);
    var avgPrice       = Model.Any() ? Model.Average(c => (double)c.DailyPrice) : 0;
}

<style>
    :root {
        --bg-dark:     #0d0f14;
        --bg-dark2:    #13161e;
        --bg-dark3:    #1a1e2a;
        --accent:      #e8ff47;
        --accent-dim:  rgba(232,255,71,.12);
        --accent2:     #4f8dff;
        --accent2-dim: rgba(79,141,255,.12);
        --accent3:     #ff9f47;
        --accent3-dim: rgba(255,159,71,.12);
        --danger:      #ff5259;
        --success:     #30e0a1;
        --border:      rgba(255,255,255,.07);
        --text:        #e2e8f0;
        --text-muted:  #7a8499;
        --radius:      12px;
        --radius-lg:   18px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .cl-root {
        padding: 28px;
        font-family: 'DM Sans', 'Segoe UI', sans-serif;
        color: var(--text);
    }

    /* ── Breadcrumb ── */
    .cl-breadcrumb {
        display: flex; align-items: center; gap: 6px;
        font-size: 12px; color: var(--text-muted); margin-bottom: 6px;
    }
    .cl-breadcrumb span { color: var(--text); }

    /* ── Page Header ── */
    .cl-page-header {
        display: flex; align-items: flex-end;
        justify-content: space-between; gap: 16px;
        margin-bottom: 24px; flex-wrap: wrap;
    }
    .cl-page-title {
        font-family: 'Syne', Georgia, sans-serif;
        font-size: 26px; font-weight: 700; color: var(--text); line-height: 1;
    }
    .cl-page-subtitle { font-size: 13px; color: var(--text-muted); margin-top: 5px; }

    /* ── Buttons ── */
    .btn-accent {
        background: var(--accent); color: #0d0f14; border: none;
        border-radius: 10px; padding: 9px 18px; font-size: 13px;
        font-weight: 600; font-family: inherit; cursor: pointer;
        display: inline-flex; align-items: center; gap: 7px;
        text-decoration: none; transition: opacity .2s;
    }
    .btn-accent:hover { opacity: .85; color: #0d0f14; }

    .btn-edit {
        background: var(--accent2-dim); color: var(--accent2);
        border: 1px solid rgba(79,141,255,.25); border-radius: 8px;
        padding: 6px 13px; font-size: 12px; font-weight: 600;
        font-family: inherit; cursor: pointer; display: inline-flex;
        align-items: center; gap: 5px; text-decoration: none; transition: background .2s;
    }
    .btn-edit:hover { background: rgba(79,141,255,.2); color: var(--accent2); }

    .btn-danger {
        background: rgba(255,82,89,.1); color: var(--danger);
        border: 1px solid rgba(255,82,89,.2); border-radius: 8px;
        padding: 6px 13px; font-size: 12px; font-weight: 600;
        font-family: inherit; cursor: pointer; display: inline-flex;
        align-items: center; gap: 5px; text-decoration: none; transition: background .2s;
    }
    .btn-danger:hover { background: rgba(255,82,89,.18); color: var(--danger); }

    /* ── Stats ── */
    .cl-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px; margin-bottom: 22px;
    }
    @@media (max-width: 900px) { .cl-stats { grid-template-columns: repeat(2,1fr); } }
    @@media (max-width: 520px) { .cl-stats { grid-template-columns: 1fr; } }

    .cl-stat-card {
        background: var(--bg-dark2); border: 1px solid var(--border);
        border-radius: var(--radius); padding: 16px 18px;
        display: flex; align-items: center; gap: 14px;
    }
    .cl-stat-icon {
        width: 40px; height: 40px; border-radius: 10px;
        display: grid; place-items: center;
        font-size: 18px; flex-shrink: 0;
    }
    .cl-stat-icon.yellow { background: var(--accent-dim);       color: var(--accent);  }
    .cl-stat-icon.green  { background: rgba(48,224,161,.1);     color: var(--success); }
    .cl-stat-icon.red    { background: rgba(255,82,89,.1);      color: var(--danger);  }
    .cl-stat-icon.orange { background: var(--accent3-dim);      color: var(--accent3); }
    .cl-stat-num   { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 700; line-height: 1; }
    .cl-stat-label { font-size: 12px; color: var(--text-muted); margin-top: 3px; }

    /* ── Toolbar ── */
    .cl-toolbar {
        display: flex; align-items: center; gap: 12px;
        margin-bottom: 18px; flex-wrap: wrap;
    }
    .cl-search-wrap { position: relative; flex: 1; min-width: 200px; max-width: 340px; }
    .cl-search-wrap input {
        width: 100%; background: var(--bg-dark2);
        border: 1px solid var(--border); border-radius: 10px;
        color: var(--text); padding: 9px 13px 9px 36px;
        font-size: 13px; font-family: inherit; outline: none;
        transition: border .2s, box-shadow .2s;
    }
    .cl-search-wrap input:focus {
        border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-dim);
    }
    .cl-search-wrap input::placeholder { color: var(--text-muted); }
    .cl-search-icon {
        position: absolute; left: 12px; top: 50%;
        transform: translateY(-50%); font-size: 14px;
        color: var(--text-muted); pointer-events: none;
    }

    .cl-filter-scroll { display: flex; gap: 6px; overflow-x: auto; padding-bottom: 2px; }
    .cl-filter-scroll::-webkit-scrollbar { display: none; }

    .cl-filter-tab {
        background: var(--bg-dark2); border: 1px solid var(--border);
        border-radius: 8px; padding: 7px 14px; font-size: 12px;
        font-weight: 500; color: var(--text-muted); cursor: pointer;
        transition: all .2s; font-family: inherit; white-space: nowrap;
    }
    .cl-filter-tab.active {
        background: var(--accent-dim); border-color: rgba(232,255,71,.3); color: var(--accent);
    }
    .cl-filter-tab:hover:not(.active) { background: var(--bg-dark3); color: var(--text); }

    /* Sort select */
    .cl-sort-select {
        background: var(--bg-dark2); border: 1px solid var(--border);
        border-radius: 10px; color: var(--text); padding: 8px 12px;
        font-size: 12px; font-family: inherit; outline: none; cursor: pointer;
    }
    .cl-sort-select:focus { border-color: var(--accent); }

    .cl-view-toggle { display: flex; gap: 4px; margin-left: auto; }
    .cl-view-btn {
        width: 34px; height: 34px; border-radius: 8px;
        border: 1px solid var(--border); background: var(--bg-dark2);
        color: var(--text-muted); cursor: pointer; display: grid;
        place-items: center; font-size: 15px; transition: all .2s;
    }
    .cl-view-btn.active {
        background: var(--accent-dim); border-color: rgba(232,255,71,.3); color: var(--accent);
    }

    /* ── Cards Grid ── */
    .cl-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }
    .cl-grid.list-view { grid-template-columns: 1fr; }

    .cl-card {
        background: var(--bg-dark2); border: 1px solid var(--border);
        border-radius: var(--radius-lg); overflow: hidden;
        transition: border-color .2s, transform .18s, box-shadow .2s;
        animation: clFadeUp .35s ease both;
    }
    .cl-card:hover {
        border-color: rgba(255,255,255,.14);
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0,0,0,.35);
    }
    @@keyframes clFadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Card image area */
    .cl-card-img {
        position: relative; height: 160px;
        background: var(--bg-dark3);
        display: flex; align-items: center; justify-content: center;
        overflow: hidden;
    }
    .cl-card-img::before {
        content: '';
        position: absolute; inset: 0;
        background: radial-gradient(circle at 70% 30%, rgba(232,255,71,.05) 0%, transparent 65%);
        pointer-events: none;
    }
    .cl-car-img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform .35s ease;
    }
    .cl-card:hover .cl-car-img { transform: scale(1.04); }
    .cl-img-placeholder {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 6px; color: var(--text-muted);
        font-size: 36px;
    }
    .cl-img-placeholder span { font-size: 12px; }

    /* Overlay badges on image */
    .cl-img-id {
        position: absolute; top: 10px; left: 10px;
        font-size: 11px; color: var(--text-muted);
        background: rgba(0,0,0,.5); border-radius: 5px; padding: 2px 7px;
    }
    .cl-avail-badge {
        position: absolute; top: 10px; right: 10px;
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 11px; font-weight: 600; padding: 3px 9px;
        border-radius: 6px;
    }
    .cl-avail-badge.yes { background: rgba(48,224,161,.12); color: var(--success); border: 1px solid rgba(48,224,161,.25); }
    .cl-avail-badge.no  { background: rgba(255,82,89,.1);   color: var(--danger);  border: 1px solid rgba(255,82,89,.2); }
    .cl-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

    /* Price overlay */
    .cl-price-pill {
        position: absolute; bottom: 10px; right: 10px;
        background: var(--accent); color: #0d0f14;
        font-family: 'Syne', sans-serif;
        font-size: 13px; font-weight: 700;
        padding: 4px 10px; border-radius: 7px;
        box-shadow: 0 2px 10px rgba(0,0,0,.3);
    }

    /* Card Body */
    .cl-card-body { padding: 14px 16px; }

    .cl-car-title {
        font-family: 'Syne', sans-serif;
        font-size: 16px; font-weight: 700; color: var(--text);
        margin-bottom: 2px;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .cl-car-plate {
        font-size: 11px; color: var(--text-muted);
        font-family: monospace; letter-spacing: .04em;
        margin-bottom: 12px;
        display: inline-flex; align-items: center; gap: 5px;
    }
    .cl-plate-tag {
        background: var(--bg-dark3); border: 1px solid var(--border);
        border-radius: 4px; padding: 1px 7px;
        color: var(--accent2); font-size: 11px; letter-spacing: .08em;
        font-weight: 600;
    }

    /* Specs pills */
    .cl-specs {
        display: flex; flex-wrap: wrap; gap: 6px;
        margin-bottom: 14px;
    }
    .cl-spec {
        display: inline-flex; align-items: center; gap: 4px;
        background: var(--bg-dark3); border: 1px solid var(--border);
        border-radius: 6px; padding: 4px 9px;
        font-size: 11px; color: var(--text-muted);
    }
    .cl-spec-icon { font-size: 12px; }

    /* Fuel & Transmission tags */
    .cl-tags { display: flex; gap: 6px; margin-bottom: 14px; flex-wrap: wrap; }
    .cl-tag {
        font-size: 11px; font-weight: 600; padding: 3px 9px;
        border-radius: 6px;
    }
    .cl-tag.fuel { background: var(--accent3-dim); color: var(--accent3); border: 1px solid rgba(255,159,71,.2); }
    .cl-tag.trans { background: var(--accent2-dim); color: var(--accent2); border: 1px solid rgba(79,141,255,.2); }
    .cl-tag.cat  { background: var(--accent-dim);  color: var(--accent);  border: 1px solid rgba(232,255,71,.2); }

    .cl-card-actions { display: flex; gap: 8px; }

    /* ── List view overrides ── */
    .cl-grid.list-view .cl-card       { display: flex; align-items: stretch; }
    .cl-grid.list-view .cl-card-img   { width: 140px; min-height: 100px; height: auto; flex-shrink: 0; border-radius: 0; }
    .cl-grid.list-view .cl-car-img    { object-fit: cover; }
    .cl-grid.list-view .cl-card-body  { flex: 1; display: flex; align-items: center; gap: 20px; padding: 14px 18px; flex-wrap: wrap; }
    .cl-grid.list-view .cl-info-main  { flex: 1; min-width: 160px; }
    .cl-grid.list-view .cl-specs      { margin-bottom: 0; }
    .cl-grid.list-view .cl-tags       { margin-bottom: 0; }
    .cl-grid.list-view .cl-car-plate  { margin-bottom: 6px; }
    .cl-grid.list-view .cl-card-actions { margin-left: auto; flex-shrink: 0; }

    /* ── Empty ── */
    .cl-empty {
        grid-column: 1 / -1;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 60px 20px; gap: 12px; color: var(--text-muted);
    }
    .cl-empty .cl-empty-icon { font-size: 42px; opacity: .45; }
    .cl-empty p { font-size: 14px; }

    /* ── Delete Modal ── */
    .cl-modal-backdrop {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,.7); z-index: 200;
        align-items: center; justify-content: center;
        backdrop-filter: blur(4px);
    }
    .cl-modal-backdrop.open { display: flex; }
    .cl-modal {
        background: var(--bg-dark2); border: 1px solid var(--border);
        border-radius: var(--radius-lg); padding: 32px 28px 28px;
        width: 100%; max-width: 380px; text-align: center; position: relative;
    }
    .cl-modal-close {
        position: absolute; top: 14px; right: 16px;
        background: none; border: none; color: var(--text-muted);
        font-size: 18px; cursor: pointer; line-height: 1;
    }
    .cl-modal-icon  { font-size: 38px; margin-bottom: 10px; }
    .cl-modal-title { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 700; margin-bottom: 10px; }
    .cl-modal-msg   { font-size: 13px; color: var(--text-muted); line-height: 1.65; margin-bottom: 24px; }
    .cl-modal-actions { display: flex; gap: 10px; justify-content: center; }

    .cl-result-info        { font-size: 12px; color: var(--text-muted); margin-bottom: 14px; }
    .cl-result-info strong { color: var(--text); }
</style>

<div class="cl-root">

    <div class="cl-breadcrumb">
        Araç Yönetimi <span>›</span> <span>Araç Listesi</span>
    </div>

    <div class="cl-page-header">
        <div>
            <h1 class="cl-page-title">Araç Yönetimi</h1>
            <p class="cl-page-subtitle">Filodaki tüm araçları görüntüleyin ve yönetin.</p>
        </div>
        <a asp-controller="Car" asp-action="Create" class="btn-accent">
            ＋ Yeni Araç Ekle
        </a>
    </div>

    <!-- Stats -->
    <div class="cl-stats">
        <div class="cl-stat-card">
            <div class="cl-stat-icon yellow">🚗</div>
            <div>
                <div class="cl-stat-num">@totalCount</div>
                <div class="cl-stat-label">Toplam Araç</div>
            </div>
        </div>
        <div class="cl-stat-card">
            <div class="cl-stat-icon green">✅</div>
            <div>
                <div class="cl-stat-num">@availableCount</div>
                <div class="cl-stat-label">Müsait</div>
            </div>
        </div>
        <div class="cl-stat-card">
            <div class="cl-stat-icon red">🔑</div>
            <div>
                <div class="cl-stat-num">@rentedCount</div>
                <div class="cl-stat-label">Kiralanmış</div>
            </div>
        </div>
        <div class="cl-stat-card">
            <div class="cl-stat-icon orange">💰</div>
            <div>
                <div class="cl-stat-num">@avgPrice.ToString("N0") ₺</div>
                <div class="cl-stat-label">Ort. Günlük Fiyat</div>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="cl-toolbar">
        <div class="cl-search-wrap">
            <span class="cl-search-icon">🔍</span>
            <input type="text" id="clSearch" placeholder="Araç, marka, plaka ara..." oninput="clRender()" />
        </div>

        <div class="cl-filter-scroll">
            <button class="cl-filter-tab active" data-filter="all"     onclick="clSetFilter('all',this)">Tümü</button>
            <button class="cl-filter-tab"        data-filter="avail"   onclick="clSetFilter('avail',this)">Müsait</button>
            <button class="cl-filter-tab"        data-filter="rented"  onclick="clSetFilter('rented',this)">Kiralanmış</button>
            <button class="cl-filter-tab"        data-filter="auto"    onclick="clSetFilter('auto',this)">Otomatik</button>
            <button class="cl-filter-tab"        data-filter="manual"  onclick="clSetFilter('manual',this)">Manuel</button>
        </div>

        <select class="cl-sort-select" id="clSort" onchange="clRender()">
            <option value="default">Sıralama</option>
            <option value="price_asc">Fiyat ↑</option>
            <option value="price_desc">Fiyat ↓</option>
            <option value="year_desc">Yeni Model</option>
            <option value="km_asc">Az KM</option>
        </select>

        <div class="cl-view-toggle">
            <button class="cl-view-btn active" id="clGridBtn" onclick="clSetView('grid')" title="Kart Görünümü">⊞</button>
            <button class="cl-view-btn"        id="clListBtn" onclick="clSetView('list')" title="Liste Görünümü">☰</button>
        </div>
    </div>

    <div class="cl-result-info" id="clResultInfo"></div>
    <div class="cl-grid" id="clGrid"></div>

</div>

<!-- Delete Confirm Modal -->
<div class="cl-modal-backdrop" id="clConfirmModal">
    <div class="cl-modal">
        <button class="cl-modal-close" onclick="clCloseModal()">✕</button>
        <div class="cl-modal-icon">🗑️</div>
        <div class="cl-modal-title">Aracı Sil</div>
        <p class="cl-modal-msg" id="clConfirmMsg"></p>
        <div class="cl-modal-actions">
            <button class="btn-accent"
                    onclick="clCloseModal()"
                    style="background:var(--bg-dark3);color:var(--text);border:1px solid var(--border);">
                İptal
            </button>
            <form id="clDeleteForm" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-danger">🗑️ Evet, Sil</button>
            </form>
        </div>
    </div>
</div>

<script>
    var CL_DATA = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(c => new {
        c.CarId,
        c.Brand,
        c.Model,
        c.ModelYear,
        c.PlateNumber,
        c.DailyPrice,
        c.SeatCount,
        c.LuggageCapacity,
        c.Mileage,
        c.IsAvailable,
        c.FuelType,
        c.TransmissionType,
        c.ImageUrl,
        CategoryName = c.Category != null ? c.Category.CategoryName : ""
    })));

    var clFilter = 'all';
    var clView   = 'grid';

    function clGetFiltered() {
        var q    = document.getElementById('clSearch').value.toLowerCase();
        var sort = document.getElementById('clSort').value;

        var items = CL_DATA.filter(function(c) {
            var matchF = clFilter === 'all'
                || (clFilter === 'avail'  &&  c.IsAvailable)
                || (clFilter === 'rented' && !c.IsAvailable)
                || (clFilter === 'auto'   && c.TransmissionType && c.TransmissionType.toLowerCase().indexOf('otomatik') !== -1)
                || (clFilter === 'manual' && c.TransmissionType && c.TransmissionType.toLowerCase().indexOf('manuel') !== -1);

            var search = (c.Brand + ' ' + c.Model + ' ' + c.PlateNumber + ' ' + c.CategoryName).toLowerCase();
            return matchF && search.indexOf(q) !== -1;
        });

        if (sort === 'price_asc')  items.sort(function(a,b){ return a.DailyPrice - b.DailyPrice; });
        if (sort === 'price_desc') items.sort(function(a,b){ return b.DailyPrice - a.DailyPrice; });
        if (sort === 'year_desc')  items.sort(function(a,b){ return b.ModelYear  - a.ModelYear;  });
        if (sort === 'km_asc')     items.sort(function(a,b){ return a.Mileage    - b.Mileage;    });

        return items;
    }

    function clSetFilter(f, el) {
        clFilter = f;
        document.querySelectorAll('.cl-filter-tab').forEach(function(t){ t.classList.remove('active'); });
        el.classList.add('active');
        clRender();
    }

    function clSetView(v) {
        clView = v;
        document.getElementById('clGridBtn').classList.toggle('active', v === 'grid');
        document.getElementById('clListBtn').classList.toggle('active', v === 'list');
        clRender();
    }

    function clFmt(price) {
        return Number(price).toLocaleString('tr-TR') + ' ₺';
    }

    function clFmtKm(km) {
        return Number(km).toLocaleString('tr-TR') + ' km';
    }

    function clRender() {
        var items = clGetFiltered();
        var grid  = document.getElementById('clGrid');
        grid.className = 'cl-grid' + (clView === 'list' ? ' list-view' : '');

        document.getElementById('clResultInfo').innerHTML =
            '<strong>' + items.length + '</strong> araç listeleniyor';

        if (items.length === 0) {
            grid.innerHTML =
                '<div class="cl-empty">' +
                    '<div class="cl-empty-icon">&#128663;</div>' +
                    '<p>Aramanızla eşleşen araç bulunamadı.</p>' +
                '</div>';
            return;
        }

        grid.innerHTML = items.map(function(c, i){ return clCardHtml(c, i); }).join('');
    }

    function clCardHtml(c, i) {
        var delay = 'animation-delay:' + (i * 0.04) + 's';

        /* Image */
        var imgHtml = c.ImageUrl
            ? '<img class="cl-car-img" src="' + clEsc(c.ImageUrl) + '" alt="' + clEsc(c.Brand + ' ' + c.Model) + '"' +
              ' onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'" />' +
              '<div class="cl-img-placeholder" style="display:none">🚗<span>Resim Yok</span></div>'
            : '<div class="cl-img-placeholder">🚗<span>Resim Yok</span></div>';

        /* Availability */
        var badge = c.IsAvailable
            ? '<span class="cl-avail-badge yes"><span class="cl-dot"></span>Müsait</span>'
            : '<span class="cl-avail-badge no"><span class="cl-dot"></span>Kiralanmış</span>';

        /* Specs */
        var specs =
            '<span class="cl-spec"><span class="cl-spec-icon">👤</span>' + c.SeatCount + ' Kişi</span>' +
            '<span class="cl-spec"><span class="cl-spec-icon">🧳</span>' + c.LuggageCapacity + ' Bagaj</span>' +
            '<span class="cl-spec"><span class="cl-spec-icon">📅</span>' + c.ModelYear + '</span>' +
            '<span class="cl-spec"><span class="cl-spec-icon">🛣️</span>' + clFmtKm(c.Mileage) + '</span>';

        /* Tags */
        var tags = '';
        if (c.FuelType)          tags += '<span class="cl-tag fuel">'  + clEsc(c.FuelType)          + '</span>';
        if (c.TransmissionType)  tags += '<span class="cl-tag trans">' + clEsc(c.TransmissionType)  + '</span>';
        if (c.CategoryName)      tags += '<span class="cl-tag cat">'   + clEsc(c.CategoryName)       + '</span>';

        /* Actions */
        var actions =
            '<div class="cl-card-actions">' +
                '<a href="/Admin/Car/UpdateCar/' + c.CarId + '" class="btn-edit">&#9999; Düzenle</a>' +
                '<button class="btn-danger" onclick="clConfirmDelete(' + c.CarId + ',\'' + clEsc(c.Brand + ' ' + c.Model) + '\')">&#128465; Sil</button>' +
            '</div>';

        if (clView === 'list') {
            return '<div class="cl-card" style="' + delay + '">' +
                       '<div class="cl-card-img">' +
                           '<span class="cl-img-id">#' + c.CarId + '</span>' +
                           imgHtml +
                           badge +
                       '</div>' +
                       '<div class="cl-card-body">' +
                           '<div class="cl-info-main">' +
                               '<div class="cl-car-title">' + clEsc(c.Brand) + ' ' + clEsc(c.Model) + '</div>' +
                               '<div class="cl-car-plate"><span class="cl-plate-tag">' + clEsc(c.PlateNumber) + '</span></div>' +
                           '</div>' +
                           '<div class="cl-specs">' + specs + '</div>' +
                           '<div class="cl-tags">' + tags + '</div>' +
                           '<div style="font-family:\'Syne\',sans-serif;font-size:15px;font-weight:700;color:var(--accent);white-space:nowrap">' + clFmt(c.DailyPrice) + '/gün</div>' +
                           actions +
                       '</div>' +
                   '</div>';
        }

        /* Grid card */
        return '<div class="cl-card" style="' + delay + '">' +
                   '<div class="cl-card-img">' +
                       '<span class="cl-img-id">#' + c.CarId + '</span>' +
                       badge +
                       imgHtml +
                       '<span class="cl-price-pill">' + clFmt(c.DailyPrice) + '/gün</span>' +
                   '</div>' +
                   '<div class="cl-card-body">' +
                       '<div class="cl-car-title">' + clEsc(c.Brand) + ' ' + clEsc(c.Model) + '</div>' +
                       '<div class="cl-car-plate"><span class="cl-plate-tag">' + clEsc(c.PlateNumber) + '</span></div>' +
                       '<div class="cl-specs">' + specs + '</div>' +
                       '<div class="cl-tags">' + tags + '</div>' +
                       actions +
                   '</div>' +
               '</div>';
    }

    function clConfirmDelete(id, name) {
        document.getElementById('clConfirmMsg').innerHTML =
            '<strong>' + clEsc(name) + '</strong> aracını silmek istediğinizden emin misiniz?<br>Bu işlem geri alınamaz.';
        document.getElementById('clDeleteForm').action = '/Admin/Car/DeleteCar/' + id;
        document.getElementById('clConfirmModal').classList.add('open');
    }

    function clCloseModal() {
        document.getElementById('clConfirmModal').classList.remove('open');
    }

    document.getElementById('clConfirmModal').addEventListener('click', function(e) {
        if (e.target === this) clCloseModal();
    });

    function clEsc(str) {
        if (!str && str !== 0) return '';
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#x27;');
    }

    clRender();
</script>


